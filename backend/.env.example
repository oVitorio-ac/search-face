## Backend environment variables
## Copy to `backend/.env` and adjust as needed.

# Flask
FLASK_ENV=development
FLASK_DEBUG=1

# Face engine
# InsightFace model package name. Common options: buffalo_l, buffalo_s, buffalo_sc
FACE_MODEL=buffalo_l
INSIGHTFACE_PROVIDERS=CPUExecutionProvider
FACE_DET_SIZE=640
FACE_CTX_ID=0

# Database (SQLAlchemy/Alembic)
# Prefer DATABASE_URL (used by Alembic + SQLAlchemy session factory)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/face_search

# docker-compose (Postgres)
POSTGRES_DB=face_search
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

# Legacy/CLI compatibility (indexer flag default)
# Still accepted by the pgvector indexing CLI, but DATABASE_URL is preferred.
PG_DSN=postgresql+psycopg://postgres:postgres@localhost:5433/face_search

# (Deprecated) table name for CLI; ignored by ORM/migrations (always uses face_vectors)
PG_TABLE=face_vectors
